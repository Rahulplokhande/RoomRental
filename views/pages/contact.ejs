<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Contact us</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, sans-serif;
      background-color: #f5f5f5;
    }

    .concontainer {
      display: flex;
      justify-content: space-around;
      align-items: center;
      min-height: 100vh;
      padding: 30px;
      gap: 20px;
      flex-wrap: wrap;
    }

    .contact-form {
      width: 45%;
      background: #fff;
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      animation: fadeInLeft 1s ease;
    }

    .contact-form h1 {
      margin-bottom: 20px;
      text-align: center;
    }

    .contact-form input,
    .contact-form textarea {
      width: 100%;
      padding: 12px;
      margin-bottom: 15px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }

    .contact-form button {
      width: 100%;
      padding: 12px;
      background-color: #4CAF50;
      color: white;
      font-size: 16px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      transition: background 0.3s ease;
    }

    .contact-form button:hover {
      background-color: #45a049;
    }

    .email-icon {
      width: 200px;
      height: 200px;
      position: relative;
      animation: bounce 2s infinite;
    }

    .email-icon svg {
      width: 100%;
      height: 100%;
      fill: #4CAF50;
    }

    @keyframes fadeInLeft {
      from {
        opacity: 0;
        transform: translateX(-50px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes bounce {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-15px);
      }
    }

    @media (max-width: 768px) {
      .concontainer {
        flex-direction: column;
      }

      .contact-form, .email-icon {
        width: 100%;
        text-align: center;
      }
    }
  </style>
  <%- include("../include/navbar.ejs") %>

</head>

<body>
  <div class="concontainer">
    <!-- Contact Form -->
    <div class="contact-form">
      <h1>Get in touch</h1>
      <form action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="ccfba76a-b48a-45ea-b095-0ebca38d73d8">
        <input type="text" name="name" autocomplete="off" placeholder="Your Name" required />
        <input type="email" name="email" autocomplete="off" placeholder="Your Email" required />
        <textarea name="message" placeholder="Your Message" required></textarea>
        <button type="submit">Submit →</button>
      </form>
    </div>

    <!-- Animated Email Icon -->
    <div class="email-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
        <path d="M2 16v32c0 3.3 2.7 6 6 6h48c3.3 0 6-2.7 6-6V16c0-3.3-2.7-6-6-6H8c-3.3 0-6 2.7-6 6zm58 0v.5L32 38 4 16.5V16c0-1.1.9-2 2-2h52c1.1 0 2 .9 2 2zM4 19.5l18.2 13.9L4 47.2v-27.7zM6.7 50L24.7 34l5.8 4.4c.7.5 1.6.5 2.3 0l5.8-4.4 18 16H6.7zm53.3-2.8L41.8 33.4 60 19.5v27.7z"/>
      </svg>
    </div>
  </div>
</body>
</html>
