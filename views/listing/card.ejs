<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Card Listing</title>
    <link rel="stylesheet" href="/css/card.css">
</head>
<body>
    <div class="property-card">
        <h2>3 BHK House For Rent In Hinjewadi Phase 1 Road <a href="#"><i class="fa fa-external-link"></i></a></h2>
        <p class="location">Independent House, Next to Wipro Company <a href="#">Explore Nearby</a></p>
        
        <div class="property-info">
            <div class="info-box">
                <h3>₹ 50,000</h3>
                <p>Rent (Non-Negotiable)</p>
            </div>
            <div class="info-box">
                <h3>₹ 1,50,000</h3>
                <p>Deposit</p>
            </div>
            <div class="info-box">
                <h3>1,500 sqft</h3>
                <p>Builtup</p>
            </div>
        </div>
    
        <div class="property-details">
            <img src="https://images.unsplash.com/photo-1552733407-5d5c46c3bb3b?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTB8fHRyYXZlbHxlbnwwfHwwfHx8MA%3D%3D&auto=format&fit=crop&w=800&q=60" alt="House Image" class="property-image">
            <div class="details">
                <p><strong>Fully Furnished</strong> <span>Furnishing</span></p>
                <p><strong>3 BHK</strong> <span>Apartment Type</span></p>
                <p><strong>Family, Female</strong> <span>Preferred Tenants</span></p>
                <p><strong>Re+ady to Move</strong> <span>Available From</span></p>
            </div>
        </div>
    
        <button class="owner-details-btn">Get Owner Details</button>
    </div>
    
</body>
</html>
