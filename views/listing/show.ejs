<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Listing Detail</title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      padding: 30px;
    }
    .navbar {
      top: 0;
      width: 100%;
      background-color: #2563eb;
      padding: 10px;
      color: white;
      position: fixed;
    }
    h1 {
        margin-top: 50px;
    }
    .property-card {
      text-align: start;
      max-width: 600px;
      margin: 0 auto;
      margin-top: 20px;
      height: auto;
    }
    .property-image {
      width: 350px;
      height: 300px;
      border-radius: 15px;
      object-fit: cover;
    }
    .buttons {
      margin-top: 20px;
    }
    .btn {
      background-color: #2563eb;
      color: white;
      border: none;
      padding: 10px 20px;
      margin: 0 10px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 16px;
    }
    .btn.delete {
      background-color: #ef4444;
    }
  </style>
</head>

<%- include("../include/navbar.ejs") %>

<body>
  <h1>Listing Detail</h1>

  <div class="property-card">
    <% if (propertys.image && propertys.image.data) { %>
      <img class="property-image" src="data:<%= propertys.image.contentType %>;base64,<%= propertys.image.data.toString('base64') %>" alt="Property Image" />
    <% } else { %>
      <img class="property-image" src="/images/default-property.jpg" alt="Default Image" />
    <% } %>

    <h2><strong><%= propertys.title %></strong></h2>
    <p><%= propertys.city %></p>
    <p><%= propertys.area %></p>
    <p><%= propertys.apartmentType %></p>
    <p>₹<%= propertys.rent %>/month</p>
    <p><%= propertys.location %></p>

    <h4>Owner Info</h4>
    <p><%= propertys.ownerDetails.ownerName %> | <%= propertys.ownerDetails.ownerContact %></p>
    <p><%= propertys.ownerDetails.ownerEmail %></p>
    <p><%= propertys.ownerDetails.ownerAddress %></p>

    <% if (propertys.isSold) { %>
      <p style="color: red; font-weight: bold;">Status: Sold</p>
    <% } else { %>
      <p style="color: green; font-weight: bold;">Status: Unsold</p>
    <% } %>
    

    <!-- <div class="buttons">
      <a href="/home/listing/<%= propertys._id %>/edit"><button class="btn">Edit</button></a>
      <form action="/home/listing/<%= propertys._id %>?_method=DELETE" method="POST" style="display:inline;">
        <button class="btn delete" onclick="return confirm('Are you sure you want to delete this listing?');">Delete</button>
      </form>
    </div> -->
    <% if (user && user._id && propertys.ownerId && user._id.toString() === propertys.ownerId.toString()) { %>
      <div class="buttons">
        <a href="/home/listing/<%= propertys._id %>/edit"><button class="btn">Edit</button></a>
        <form action="/home/listing/<%= propertys._id %>?_method=DELETE" method="POST" style="display:inline;">
          <button class="btn delete" onclick="return confirm('Are you sure you want to delete this listing?');">Delete</button>
        </form>
      </div>
    <% } %>
    
  </div>
</body>
</html>
