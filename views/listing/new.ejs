<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/card.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://getbootstrap.com/docs/5.3/assets/css/docs.css" rel="stylesheet">
</head>
<%- include("../include/navbar.ejs") %>
<body>
    
    <div class="row newForm">
        <div class="col-7">
          <h3>Add your new Listing</h3>
          <form method="POST" action="/home/listing" enctype="multipart/form-data" novalidate class="needs-validation">
      
            <div class="mb-3">
              <label for="title" class="form-label">Title</label>
              <input name="property[title]" autocomplete="off" placeholder="Sharad Recidency" type="text" class="form-control" required />
              <div class="invalid-feedback">Please enter a valid title</div>
            </div>
      
            <div class="mb-3">
              <label for="city" class="form-label">City</label>
              <input name="property[city]" autocomplete="off" placeholder="Kodoli"  type="text" class="form-control" required />
              <div class="invalid-feedback">Please enter a valid city</div>
            </div>
            
            <div class="mb-3">
              <label for="area" class="form-label">Location / Area</label>
              <input name="property[area]" autocomplete="off" placeholder="Shenday Colony, Near Bank Of India" type="text" class="form-control" required />
              <div class="invalid-feedback">Please enter a valid area</div>
            </div>            

            <div class="mb-3">
              <label for="rent" class="form-label">Rent (₹)</label>
              <input name="property[rent]" autocomplete="off" placeholder="3000" type="number" class="form-control" required />
              <div class="invalid-feedback">Please enter a valid rent amount</div>
            </div>

            <div class="mb-3">
              <label for="apartmentType" class="form-label">Apartment Type</label>
              <select name="property[apartmentType]" class="form-control" required>
                <option value="">Select Apartment Type</option>
                <option value="1 RK">RK</option>
                <option value="1 BHK">1 BHK</option>
                <option value="2 BHK">2 BHK</option>
                <option value="3 BHK">3 BHK</option>
              </select>
              <div class="invalid-feedback">Please select an apartment type</div>
            </div>

            <div class="mb-3">
              <label for="image" class="form-label">Upload Image</label>
              <div class="upload">
                <input name="property[image]" autocomplete="off" type="file" class="form-control" required />
              </div>
            </div>

            <div class="row">
              <div class="mb-3 col-md-6">
                <label for="ownerDetails" class="form-label">Owner Name</label>
                <input name="property[ownerDetails.ownerName]" autocomplete="off" placeholder="Owner Name " type="text" class="form-control" required />
                <div class="invalid-feedback">Please enter valid owner details</div>
              </div>

              <div class="mb-3 col-md-6">
                <label for="ownerDetails" class="form-label">Owner Contact</label>
                <input name="property[ownerDetails.ownerContact]" autocomplete="off" placeholder="Owner Contact No." type="number" class="form-control" required />
                <div class="invalid-feedback">Please enter valid owner details</div>
              </div>
            </div>

            <div class="row">
              <div class="mb-3 col-md-6">
                <label for="ownerDetails" class="form-label">Owner Email</label>
                <input name="property[ownerDetails.ownerEmail]" autocomplete="off" placeholder="Owner Email" type="email" class="form-control" required />
                <div class="invalid-feedback">Please enter valid owner details</div>
              </div>

              <div class="mb-3 col-md-6">
                <label for="ownerDetails" class="form-label">Owner Address</label>
                <input name="property[ownerDetails.ownerAddress]" autocomplete="off" placeholder="Owner Address" type="text" class="form-control" required />
                <div class="invalid-feedback">Please enter valid owner details</div>
              </div>
            </div>
      
            <br>
            <button class="btn btn-primary">Add Listing</button>
          </form>
        </div>
    </div>
    <%- include("../include/footer.ejs") %>
</body>
</html>
