<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rent Booking Home</title>
    <link rel="stylesheet" href="css/home.css">

    <!-- <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" /> -->
    <!-- <link rel="preconnect" href="https://fonts.googleapis.com"> -->
    <!-- <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> -->
    <!-- <link href="https://fonts.googleapis.com/css2?family=Gupter:wght@400;500;700&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet"> -->

</head>
<body>
    
    <%- include("../include/navbar.ejs") %>
    <section class="hero">
        <div class="overlay"></div>
        <div class="hero-content">
          <h2 class="fade-slide">Find Your Perfect Rental Home</h2>
          <p class="fade-slide delay-1">Explore the best properties available for rent</p>

          <div class="search-box fade-slide delay-2 position-relative">
            <form action="/search" method="GET" autocomplete="off">
              <input 
                type="text" 
                class="search-text form-control" 
                id="city-input" 
                name="city" 
                list="city-list" 
                placeholder="Search for city, area..." 
                required
              />
              <datalist id="city-list">
                <option value="Kodoli">
                <option value="Warananagar">
                <option value="Amruthnagar">
                <option value="Bahirewadi">
                <option value="Pargoan">
                <option value="Pune">
               
              </datalist>
              <button type="submit" class="btn btn-primary mt-2">Search</button>
            </form>
          </div>
        </div>
      </section>
    <%- include("../include/footer.ejs") %>
   
    
</body>
</html>