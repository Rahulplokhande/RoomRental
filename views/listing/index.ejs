<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/card.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<%- include("../include/navbar.ejs") %>

<body>
  <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1 card-con">
    <% for(let property of allProperties) { %>
      <a class="card-list" href="/home/listing/<%= property._id %>" >
        <div class="card col">
          <div class="imgs">
            <% if (property.image && property.image.data) { %>
              <img src="data:<%= property.image.contentType %>;base64,<%= property.image.data.toString('base64') %>" class="card-img-top" alt="listing image" />
            <% } else { %>
              <img src="/default.jpg" class="card-img-top" alt="default listing image" />
            <% } %>
          </div>
    
          <div class="card-body">
            <p class="card-text">
              <b class="property-title"><%= property.title %></b><br>
              <%= property.city %><br>            
              ₹ <%= property.rent.toLocaleString() %>/month
              <% if (property.isSold) { %>
                <p style="color: red; font-weight: bold; text-align: center;">Status: Sold</p>
              <% } else { %>
                <p style="color: green; font-weight: bold; text-align: center;">Status: Unsold</p>
              <% } %>   
            </p>
          </div>
        </div>
      </a>
    <% } %>
  </div>
</body>
<%- include("../include/footer.ejs") %>
</html>